# Qiskit IBM Runtime MCP Server Configuration

# IBM Quantum API token (optional when saved Qiskit credentials exist)
# Get your token from: https://quantum.cloud.ibm.com/
QISKIT_IBM_TOKEN=your_ibm_quantum_token_here

# Explicit Runtime instance used by every provider operation (required)
QISKIT_IBM_RUNTIME_MCP_INSTANCE=your_instance_crn_here
