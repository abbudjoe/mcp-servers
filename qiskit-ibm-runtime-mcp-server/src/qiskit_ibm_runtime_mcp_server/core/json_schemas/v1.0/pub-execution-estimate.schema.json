{
  "$id": "https://qiskit.org/schemas/runtime-research/v1.0/pub-execution-estimate.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "One caller-supplied generic PUB execution estimate used for partitioning.",
  "properties": {
    "estimated_qpu_seconds": {
      "minimum": 0,
      "title": "Estimated Qpu Seconds",
      "type": "number"
    },
    "pub_id": {
      "minLength": 1,
      "title": "Pub Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "pub_id",
    "estimated_qpu_seconds"
  ],
  "title": "PubExecutionEstimate",
  "type": "object",
  "x-schema-version": "1.0"
}
