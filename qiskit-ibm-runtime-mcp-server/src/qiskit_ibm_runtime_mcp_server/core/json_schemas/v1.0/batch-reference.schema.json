{
  "$id": "https://qiskit.org/schemas/runtime-contracts/v1.0/batch-reference.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Stable identity returned when a Runtime Batch is created or reattached.",
  "properties": {
    "backend_name": {
      "minLength": 1,
      "title": "Backend Name",
      "type": "string"
    },
    "batch_id": {
      "minLength": 1,
      "title": "Batch Id",
      "type": "string"
    },
    "instance_id": {
      "minLength": 1,
      "title": "Instance Id",
      "type": "string"
    },
    "maximum_time_seconds": {
      "exclusiveMinimum": 0,
      "title": "Maximum Time Seconds",
      "type": "integer"
    },
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "batch_id",
    "instance_id",
    "backend_name",
    "maximum_time_seconds",
    "observed_at"
  ],
  "title": "BatchReference",
  "type": "object",
  "x-schema-version": "1.0"
}
