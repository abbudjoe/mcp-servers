{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": true,
      "description": "Portable reference to immutable content-addressed bytes.",
      "properties": {
        "artifact_id": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_uri": {
          "minLength": 1,
          "title": "Storage Uri",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "artifact_id",
        "kind",
        "media_type",
        "size_bytes",
        "storage_uri"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "CircuitProvenance": {
      "additionalProperties": true,
      "description": "Typed origin and transformation record for immutable circuit bytes.",
      "properties": {
        "compiler_target_hash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compiler Target Hash"
        },
        "software_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Software Versions",
          "type": "object"
        },
        "source_artifact_id": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Artifact Id"
        },
        "source_circuit_hash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Circuit Hash"
        },
        "target_hash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Hash"
        },
        "target_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Name"
        },
        "transformation": {
          "enum": [
            "source",
            "transpile"
          ],
          "title": "Transformation",
          "type": "string"
        },
        "transpiler_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transpiler Name"
        },
        "transpiler_options": {
          "additionalProperties": true,
          "title": "Transpiler Options",
          "type": "object"
        }
      },
      "required": [
        "transformation",
        "software_versions"
      ],
      "title": "CircuitProvenance",
      "type": "object"
    },
    "CircuitRegister": {
      "additionalProperties": true,
      "description": "One named register and its exact positions in the circuit bit arrays.",
      "properties": {
        "bit_indices": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Bit Indices",
          "type": "array"
        },
        "kind": {
          "enum": [
            "quantum",
            "classical"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "size": {
          "minimum": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "kind",
        "name",
        "size",
        "bit_indices"
      ],
      "title": "CircuitRegister",
      "type": "object"
    }
  },
  "$id": "https://qiskit.org/schemas/runtime-contracts/v1.0/circuit-artifact.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Exact serialized circuit plus structural and writer provenance.",
  "properties": {
    "artifact": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "circuit_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Circuit Hash",
      "type": "string"
    },
    "depth": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Depth"
    },
    "format": {
      "enum": [
        "qpy",
        "qasm3"
      ],
      "title": "Format",
      "type": "string"
    },
    "layout": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "title": "Layout"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "num_clbits": {
      "minimum": 0,
      "title": "Num Clbits",
      "type": "integer"
    },
    "num_qubits": {
      "minimum": 0,
      "title": "Num Qubits",
      "type": "integer"
    },
    "parameter_names": {
      "items": {
        "type": "string"
      },
      "title": "Parameter Names",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/CircuitProvenance"
    },
    "qiskit_version": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Qiskit Version"
    },
    "qpy_symbolic_encoding": {
      "anyOf": [
        {
          "maxLength": 1,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Qpy Symbolic Encoding"
    },
    "qpy_version": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Qpy Version"
    },
    "reader_qiskit_version": {
      "minLength": 1,
      "title": "Reader Qiskit Version",
      "type": "string"
    },
    "registers": {
      "items": {
        "$ref": "#/$defs/CircuitRegister"
      },
      "title": "Registers",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "size": {
      "minimum": 0,
      "title": "Size",
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "artifact",
    "format",
    "circuit_hash",
    "num_qubits",
    "num_clbits",
    "size",
    "depth",
    "parameter_names",
    "registers",
    "metadata",
    "qiskit_version",
    "reader_qiskit_version",
    "qpy_version",
    "qpy_symbolic_encoding",
    "layout",
    "provenance"
  ],
  "title": "CircuitArtifact",
  "type": "object",
  "x-schema-version": "1.0"
}
