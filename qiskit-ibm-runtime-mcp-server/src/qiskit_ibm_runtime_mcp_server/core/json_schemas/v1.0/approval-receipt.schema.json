{
  "$id": "https://qiskit.org/schemas/runtime-research/v1.0/approval-receipt.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Approval bound to an exact plan hash and explicit resource allowlists.",
  "properties": {
    "allow_paid_fallback": {
      "default": false,
      "title": "Allow Paid Fallback",
      "type": "boolean"
    },
    "allowed_backends": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Allowed Backends",
      "type": "array"
    },
    "allowed_instance_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Allowed Instance Ids",
      "type": "array"
    },
    "approved_at": {
      "format": "date-time",
      "title": "Approved At",
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "max_qpu_seconds": {
      "exclusiveMinimum": 0,
      "title": "Max Qpu Seconds",
      "type": "number"
    },
    "plan_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Plan Hash",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "plan_hash",
    "approved_at",
    "expires_at",
    "max_qpu_seconds",
    "allowed_instance_ids",
    "allowed_backends"
  ],
  "title": "ApprovalReceipt",
  "type": "object",
  "x-schema-version": "1.0"
}
