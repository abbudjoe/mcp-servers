{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": true,
      "description": "Portable reference to immutable content-addressed bytes.",
      "properties": {
        "artifact_id": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_uri": {
          "minLength": 1,
          "title": "Storage Uri",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "artifact_id",
        "kind",
        "media_type",
        "size_bytes",
        "storage_uri"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "InlineJsonValue": {
      "additionalProperties": true,
      "description": "Explicit inline branch for values that may instead be artifact-backed.",
      "properties": {
        "kind": {
          "const": "inline_json",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "value"
      ],
      "title": "InlineJsonValue",
      "type": "object"
    },
    "JsonValue": {},
    "ShapedResultValue": {
      "additionalProperties": true,
      "description": "Array/scalar result whose shape survives inline and artifact storage.",
      "properties": {
        "dtype": {
          "minLength": 1,
          "title": "Dtype",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Shape",
          "type": "array"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "schema_version",
        "shape",
        "dtype",
        "value"
      ],
      "title": "ShapedResultValue",
      "type": "object"
    }
  },
  "$id": "https://qiskit.org/schemas/runtime-contracts/v1.0/estimator-pub-result.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Ordered result for one Estimator PUB without collapsing array shape.",
  "properties": {
    "data_bin_shape": {
      "items": {
        "minimum": 0,
        "type": "integer"
      },
      "title": "Data Bin Shape",
      "type": "array"
    },
    "ensemble_standard_error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ShapedResultValue"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "expectation_values": {
      "$ref": "#/$defs/ShapedResultValue"
    },
    "extensions": {
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/$defs/InlineJsonValue"
          },
          {
            "$ref": "#/$defs/ArtifactRef"
          }
        ]
      },
      "title": "Extensions",
      "type": "object"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "pub_id": {
      "minLength": 1,
      "title": "Pub Id",
      "type": "string"
    },
    "pub_index": {
      "minimum": 0,
      "title": "Pub Index",
      "type": "integer"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "standard_deviations": {
      "anyOf": [
        {
          "$ref": "#/$defs/ShapedResultValue"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "schema_version",
    "pub_id",
    "pub_index",
    "data_bin_shape",
    "expectation_values"
  ],
  "title": "EstimatorPubResult",
  "type": "object",
  "x-schema-version": "1.0"
}
