{
  "$id": "https://qiskit.org/schemas/runtime-contracts/v1.0/runtime-usage.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Typed usage returned to callers for their own reconciliation.",
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "job_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Job Id"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "quantum_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Quantum Seconds"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "usage_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Usage Type"
    }
  },
  "required": [
    "schema_version",
    "quantum_seconds"
  ],
  "title": "RuntimeUsage",
  "type": "object",
  "x-schema-version": "1.0"
}
