{
  "$id": "https://qiskit.org/schemas/runtime-contracts/v1.0/artifact-ref.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Portable reference to immutable content-addressed bytes.",
  "properties": {
    "artifact_id": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Artifact Id",
      "type": "string"
    },
    "kind": {
      "minLength": 1,
      "title": "Kind",
      "type": "string"
    },
    "media_type": {
      "minLength": 1,
      "title": "Media Type",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "size_bytes": {
      "minimum": 0,
      "title": "Size Bytes",
      "type": "integer"
    },
    "storage_uri": {
      "minLength": 1,
      "title": "Storage Uri",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "artifact_id",
    "kind",
    "media_type",
    "size_bytes",
    "storage_uri"
  ],
  "title": "ArtifactRef",
  "type": "object",
  "x-schema-version": "1.0"
}
