{
  "$defs": {
    "BatchJobUsage": {
      "additionalProperties": false,
      "description": "Per-job QPU usage recovered without interpreting scientific results.",
      "properties": {
        "job_id": {
          "minLength": 1,
          "title": "Job Id",
          "type": "string"
        },
        "quantum_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Quantum Seconds"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "job_id",
        "quantum_seconds"
      ],
      "title": "BatchJobUsage",
      "type": "object"
    },
    "BatchUsage": {
      "additionalProperties": false,
      "description": "Batch-wide and per-job usage for caller-owned reconciliation.",
      "properties": {
        "batch_id": {
          "minLength": 1,
          "title": "Batch Id",
          "type": "string"
        },
        "batch_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Batch Seconds"
        },
        "jobs": {
          "items": {
            "$ref": "#/$defs/BatchJobUsage"
          },
          "title": "Jobs",
          "type": "array"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "batch_id",
        "batch_seconds",
        "jobs",
        "retrieved_at"
      ],
      "title": "BatchUsage",
      "type": "object"
    }
  },
  "$id": "https://qiskit.org/schemas/runtime-research/v1.0/usage-reconciliation.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Estimated, approved, and actual usage kept together for callers.",
  "properties": {
    "actual_qpu_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Actual Qpu Seconds"
    },
    "approval_max_qpu_seconds": {
      "exclusiveMinimum": 0,
      "title": "Approval Max Qpu Seconds",
      "type": "number"
    },
    "batch_usage": {
      "$ref": "#/$defs/BatchUsage"
    },
    "estimated_qpu_seconds": {
      "minimum": 0,
      "title": "Estimated Qpu Seconds",
      "type": "number"
    },
    "plan_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Plan Hash",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "plan_hash",
    "estimated_qpu_seconds",
    "approval_max_qpu_seconds",
    "actual_qpu_seconds",
    "batch_usage"
  ],
  "title": "UsageReconciliation",
  "type": "object",
  "x-schema-version": "1.0"
}
