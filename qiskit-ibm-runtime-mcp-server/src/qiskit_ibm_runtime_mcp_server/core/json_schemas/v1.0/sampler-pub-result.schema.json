{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": true,
      "description": "Portable reference to immutable content-addressed bytes.",
      "properties": {
        "artifact_id": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_uri": {
          "minLength": 1,
          "title": "Storage Uri",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "artifact_id",
        "kind",
        "media_type",
        "size_bytes",
        "storage_uri"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "InlineJsonValue": {
      "additionalProperties": true,
      "description": "Explicit inline branch for values that may instead be artifact-backed.",
      "properties": {
        "kind": {
          "const": "inline_json",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "value"
      ],
      "title": "InlineJsonValue",
      "type": "object"
    },
    "JsonValue": {},
    "SamplerRegisterResult": {
      "additionalProperties": true,
      "description": "One named classical register returned in a Sampler DataBin.",
      "properties": {
        "bitstrings_by_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Bitstrings By Location"
        },
        "counts_by_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Counts By Location"
        },
        "extensions": {
          "additionalProperties": {
            "anyOf": [
              {
                "$ref": "#/$defs/InlineJsonValue"
              },
              {
                "$ref": "#/$defs/ArtifactRef"
              }
            ]
          },
          "title": "Extensions",
          "type": "object"
        },
        "num_bits": {
          "exclusiveMinimum": 0,
          "title": "Num Bits",
          "type": "integer"
        },
        "num_shots": {
          "exclusiveMinimum": 0,
          "title": "Num Shots",
          "type": "integer"
        },
        "packed_bytes": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Packed Bytes"
        },
        "packed_shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Packed Shape",
          "type": "array"
        },
        "pub_shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Pub Shape",
          "type": "array"
        },
        "quasi_distributions_by_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Quasi Distributions By Location"
        },
        "register_name": {
          "minLength": 1,
          "title": "Register Name",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "register_name",
        "pub_shape",
        "num_shots",
        "num_bits",
        "packed_shape",
        "packed_bytes",
        "counts_by_location",
        "bitstrings_by_location",
        "quasi_distributions_by_location"
      ],
      "title": "SamplerRegisterResult",
      "type": "object"
    }
  },
  "$id": "https://qiskit.org/schemas/runtime-research/v1.0/sampler-pub-result.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Ordered result for one Sampler PUB.",
  "properties": {
    "data_bin_shape": {
      "items": {
        "minimum": 0,
        "type": "integer"
      },
      "title": "Data Bin Shape",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/$defs/InlineJsonValue"
          },
          {
            "$ref": "#/$defs/ArtifactRef"
          }
        ]
      },
      "title": "Extensions",
      "type": "object"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "pub_id": {
      "minLength": 1,
      "title": "Pub Id",
      "type": "string"
    },
    "pub_index": {
      "minimum": 0,
      "title": "Pub Index",
      "type": "integer"
    },
    "registers": {
      "items": {
        "$ref": "#/$defs/SamplerRegisterResult"
      },
      "title": "Registers",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "pub_id",
    "pub_index",
    "data_bin_shape",
    "registers"
  ],
  "title": "SamplerPubResult",
  "type": "object",
  "x-schema-version": "1.0"
}
