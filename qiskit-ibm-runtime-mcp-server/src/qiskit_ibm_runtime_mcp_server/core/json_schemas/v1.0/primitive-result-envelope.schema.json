{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": true,
      "description": "Portable reference to immutable content-addressed bytes.",
      "properties": {
        "artifact_id": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_uri": {
          "minLength": 1,
          "title": "Storage Uri",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "artifact_id",
        "kind",
        "media_type",
        "size_bytes",
        "storage_uri"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "EstimatorPubResult": {
      "additionalProperties": true,
      "description": "Ordered result for one Estimator PUB without collapsing array shape.",
      "properties": {
        "ensemble_standard_error": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ensemble Standard Error"
        },
        "expectation_values": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Expectation Values"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "pub_id": {
          "minLength": 1,
          "title": "Pub Id",
          "type": "string"
        },
        "pub_index": {
          "minimum": 0,
          "title": "Pub Index",
          "type": "integer"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "standard_deviations": {
          "anyOf": [
            {
              "$ref": "#/$defs/InlineJsonValue"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            }
          ],
          "title": "Standard Deviations"
        }
      },
      "required": [
        "schema_version",
        "pub_id",
        "pub_index",
        "expectation_values",
        "standard_deviations"
      ],
      "title": "EstimatorPubResult",
      "type": "object"
    },
    "InlineJsonValue": {
      "additionalProperties": true,
      "description": "Explicit inline branch for values that may instead be artifact-backed.",
      "properties": {
        "kind": {
          "const": "inline_json",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "value"
      ],
      "title": "InlineJsonValue",
      "type": "object"
    },
    "JsonValue": {},
    "RuntimeUsage": {
      "additionalProperties": true,
      "description": "Typed usage returned to callers for their own reconciliation.",
      "properties": {
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Job Id"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "quantum_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Quantum Seconds"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "usage_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Usage Type"
        }
      },
      "required": [
        "schema_version",
        "quantum_seconds"
      ],
      "title": "RuntimeUsage",
      "type": "object"
    },
    "SamplerPubResult": {
      "additionalProperties": true,
      "description": "Ordered result for one Sampler PUB.",
      "properties": {
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "pub_id": {
          "minLength": 1,
          "title": "Pub Id",
          "type": "string"
        },
        "pub_index": {
          "minimum": 0,
          "title": "Pub Index",
          "type": "integer"
        },
        "registers": {
          "items": {
            "$ref": "#/$defs/SamplerRegisterResult"
          },
          "title": "Registers",
          "type": "array"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "pub_id",
        "pub_index",
        "registers"
      ],
      "title": "SamplerPubResult",
      "type": "object"
    },
    "SamplerRegisterResult": {
      "additionalProperties": true,
      "description": "One named classical register returned in a Sampler DataBin.",
      "properties": {
        "bitstrings_by_location": {
          "anyOf": [
            {
              "items": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "type": "array"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bitstrings By Location"
        },
        "counts_by_location": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": {
                  "minimum": 0,
                  "type": "integer"
                },
                "type": "object"
              },
              "type": "array"
            },
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Counts By Location"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "num_bits": {
          "exclusiveMinimum": 0,
          "title": "Num Bits",
          "type": "integer"
        },
        "num_shots": {
          "exclusiveMinimum": 0,
          "title": "Num Shots",
          "type": "integer"
        },
        "pub_shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Pub Shape",
          "type": "array"
        },
        "register_name": {
          "minLength": 1,
          "title": "Register Name",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "register_name",
        "pub_shape",
        "num_shots",
        "num_bits"
      ],
      "title": "SamplerRegisterResult",
      "type": "object"
    }
  },
  "$id": "https://qiskit.org/schemas/runtime-research/v1.0/primitive-result-envelope.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Complete ordered Primitive V2 job result and unknown extension data.",
  "properties": {
    "actual_qpu_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Actual Qpu Seconds"
    },
    "backend_name": {
      "minLength": 1,
      "title": "Backend Name",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "job_id": {
      "minLength": 1,
      "title": "Job Id",
      "type": "string"
    },
    "job_metadata": {
      "additionalProperties": true,
      "title": "Job Metadata",
      "type": "object"
    },
    "primitive": {
      "enum": [
        "sampler",
        "estimator"
      ],
      "title": "Primitive",
      "type": "string"
    },
    "pub_results": {
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/SamplerPubResult"
          },
          {
            "$ref": "#/$defs/EstimatorPubResult"
          }
        ]
      },
      "title": "Pub Results",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "usage": {
      "anyOf": [
        {
          "$ref": "#/$defs/RuntimeUsage"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "schema_version",
    "primitive",
    "job_id",
    "backend_name",
    "pub_results",
    "job_metadata",
    "actual_qpu_seconds"
  ],
  "title": "PrimitiveResultEnvelope",
  "type": "object",
  "x-schema-version": "1.0"
}
