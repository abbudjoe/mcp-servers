{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": true,
      "description": "Portable reference to immutable content-addressed bytes.",
      "properties": {
        "artifact_id": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_uri": {
          "minLength": 1,
          "title": "Storage Uri",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "artifact_id",
        "kind",
        "media_type",
        "size_bytes",
        "storage_uri"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "CircuitArtifact": {
      "additionalProperties": true,
      "description": "Exact serialized circuit plus structural and writer provenance.",
      "properties": {
        "artifact": {
          "$ref": "#/$defs/ArtifactRef"
        },
        "circuit_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Circuit Hash",
          "type": "string"
        },
        "depth": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Depth"
        },
        "format": {
          "enum": [
            "qpy",
            "qasm3"
          ],
          "title": "Format",
          "type": "string"
        },
        "layout": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "title": "Layout"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "num_clbits": {
          "minimum": 0,
          "title": "Num Clbits",
          "type": "integer"
        },
        "num_qubits": {
          "minimum": 0,
          "title": "Num Qubits",
          "type": "integer"
        },
        "parameter_names": {
          "items": {
            "type": "string"
          },
          "title": "Parameter Names",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/CircuitProvenance"
        },
        "qiskit_version": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Qiskit Version"
        },
        "qpy_symbolic_encoding": {
          "anyOf": [
            {
              "maxLength": 1,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Qpy Symbolic Encoding"
        },
        "qpy_version": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Qpy Version"
        },
        "reader_qiskit_version": {
          "minLength": 1,
          "title": "Reader Qiskit Version",
          "type": "string"
        },
        "registers": {
          "items": {
            "$ref": "#/$defs/CircuitRegister"
          },
          "title": "Registers",
          "type": "array"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "size": {
          "minimum": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "schema_version",
        "artifact",
        "format",
        "circuit_hash",
        "num_qubits",
        "num_clbits",
        "size",
        "depth",
        "parameter_names",
        "registers",
        "metadata",
        "qiskit_version",
        "reader_qiskit_version",
        "qpy_version",
        "qpy_symbolic_encoding",
        "layout",
        "provenance"
      ],
      "title": "CircuitArtifact",
      "type": "object"
    },
    "CircuitProvenance": {
      "additionalProperties": true,
      "description": "Typed origin and transformation record for immutable circuit bytes.",
      "properties": {
        "compiler_target_hash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compiler Target Hash"
        },
        "software_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Software Versions",
          "type": "object"
        },
        "source_artifact_id": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Artifact Id"
        },
        "source_circuit_hash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Circuit Hash"
        },
        "target_hash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Hash"
        },
        "target_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Name"
        },
        "transformation": {
          "enum": [
            "source",
            "transpile"
          ],
          "title": "Transformation",
          "type": "string"
        },
        "transpiler_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transpiler Name"
        },
        "transpiler_options": {
          "additionalProperties": true,
          "title": "Transpiler Options",
          "type": "object"
        }
      },
      "required": [
        "transformation",
        "software_versions"
      ],
      "title": "CircuitProvenance",
      "type": "object"
    },
    "CircuitRegister": {
      "additionalProperties": true,
      "description": "One named register and its exact positions in the circuit bit arrays.",
      "properties": {
        "bit_indices": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Bit Indices",
          "type": "array"
        },
        "kind": {
          "enum": [
            "quantum",
            "classical"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "size": {
          "minimum": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "kind",
        "name",
        "size",
        "bit_indices"
      ],
      "title": "CircuitRegister",
      "type": "object"
    },
    "EstimatorPubSpec": {
      "additionalProperties": true,
      "description": "Validated EstimatorV2 PUB input with explicit observable semantics.",
      "properties": {
        "circuit": {
          "$ref": "#/$defs/CircuitArtifact"
        },
        "observables": {
          "discriminator": {
            "mapping": {
              "pauli_observables": "#/$defs/PauliObservables",
              "sparse_pauli_hamiltonian": "#/$defs/SparsePauliHamiltonian"
            },
            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/PauliObservables"
            },
            {
              "$ref": "#/$defs/SparsePauliHamiltonian"
            }
          ],
          "title": "Observables"
        },
        "parameter_values": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParameterBindings"
            },
            {
              "type": "null"
            }
          ]
        },
        "precision": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Precision"
        },
        "pub_id": {
          "minLength": 1,
          "title": "Pub Id",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "pub_id",
        "circuit",
        "observables",
        "parameter_values",
        "precision"
      ],
      "title": "EstimatorPubSpec",
      "type": "object"
    },
    "JsonValue": {},
    "ParameterBindings": {
      "additionalProperties": true,
      "description": "Deterministic named parameter values with an explicit broadcast shape.",
      "properties": {
        "parameter_names": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Parameter Names",
          "type": "array"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Shape",
          "type": "array"
        },
        "values": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "schema_version",
        "parameter_names",
        "shape",
        "values"
      ],
      "title": "ParameterBindings",
      "type": "object"
    },
    "PauliObservables": {
      "additionalProperties": true,
      "description": "A broadcast collection of separate Pauli observables.",
      "properties": {
        "kind": {
          "const": "pauli_observables",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Shape",
          "type": "array"
        },
        "values": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "shape",
        "values"
      ],
      "title": "PauliObservables",
      "type": "object"
    },
    "PubShape": {
      "additionalProperties": true,
      "description": "Resolved Primitive V2 broadcast and execution cardinality for one PUB.",
      "properties": {
        "circuit_executions": {
          "exclusiveMinimum": 0,
          "title": "Circuit Executions",
          "type": "integer"
        },
        "observable_shape": {
          "anyOf": [
            {
              "items": {
                "minimum": 0,
                "type": "integer"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "title": "Observable Shape"
        },
        "parameter_shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Parameter Shape",
          "type": "array"
        },
        "pub_id": {
          "minLength": 1,
          "title": "Pub Id",
          "type": "string"
        },
        "result_shape": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "title": "Result Shape",
          "type": "array"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "pub_id",
        "parameter_shape",
        "observable_shape",
        "result_shape",
        "circuit_executions"
      ],
      "title": "PubShape",
      "type": "object"
    },
    "SamplerPubSpec": {
      "additionalProperties": true,
      "description": "Validated SamplerV2 PUB input.",
      "properties": {
        "circuit": {
          "$ref": "#/$defs/CircuitArtifact"
        },
        "parameter_values": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParameterBindings"
            },
            {
              "type": "null"
            }
          ]
        },
        "pub_id": {
          "minLength": 1,
          "title": "Pub Id",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "shots": {
          "exclusiveMinimum": 0,
          "title": "Shots",
          "type": "integer"
        }
      },
      "required": [
        "schema_version",
        "pub_id",
        "circuit",
        "parameter_values",
        "shots"
      ],
      "title": "SamplerPubSpec",
      "type": "object"
    },
    "ScheduledPubEstimate": {
      "additionalProperties": true,
      "description": "Auditable locked-method QPU estimate for one resolved PUB.",
      "properties": {
        "circuit_executions": {
          "exclusiveMinimum": 0,
          "title": "Circuit Executions",
          "type": "integer"
        },
        "conservative_cycle_seconds": {
          "exclusiveMinimum": 0,
          "title": "Conservative Cycle Seconds",
          "type": "number"
        },
        "estimated_qpu_seconds": {
          "exclusiveMinimum": 0,
          "title": "Estimated Qpu Seconds",
          "type": "number"
        },
        "physical_circuit_executions": {
          "exclusiveMinimum": 0,
          "title": "Physical Circuit Executions",
          "type": "integer"
        },
        "pub_id": {
          "minLength": 1,
          "title": "Pub Id",
          "type": "string"
        },
        "repetitions_per_execution": {
          "exclusiveMinimum": 0,
          "title": "Repetitions Per Execution",
          "type": "integer"
        },
        "scheduled_circuit_seconds": {
          "exclusiveMinimum": 0,
          "title": "Scheduled Circuit Seconds",
          "type": "number"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "treatment_multiplier": {
          "exclusiveMinimum": 0,
          "title": "Treatment Multiplier",
          "type": "number"
        }
      },
      "required": [
        "schema_version",
        "pub_id",
        "scheduled_circuit_seconds",
        "conservative_cycle_seconds",
        "circuit_executions",
        "physical_circuit_executions",
        "repetitions_per_execution",
        "treatment_multiplier",
        "estimated_qpu_seconds"
      ],
      "title": "ScheduledPubEstimate",
      "type": "object"
    },
    "SparsePauliHamiltonian": {
      "additionalProperties": true,
      "description": "One weighted Hamiltonian, kept distinct from separate observables.",
      "properties": {
        "kind": {
          "const": "sparse_pauli_hamiltonian",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "terms": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ],
            "type": "array"
          },
          "minItems": 1,
          "title": "Terms",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "terms"
      ],
      "title": "SparsePauliHamiltonian",
      "type": "object"
    },
    "SubmissionPartition": {
      "additionalProperties": true,
      "description": "Deterministic grouping of PUB identities for one Runtime job.",
      "properties": {
        "estimated_qpu_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Qpu Seconds"
        },
        "maximum_execution_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Execution Seconds"
        },
        "partition_id": {
          "minLength": 1,
          "title": "Partition Id",
          "type": "string"
        },
        "pub_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Pub Ids",
          "type": "array"
        },
        "schema_version": {
          "const": "1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "partition_id",
        "pub_ids"
      ],
      "title": "SubmissionPartition",
      "type": "object"
    }
  },
  "$id": "https://qiskit.org/schemas/runtime-research/v1.0/submission-plan.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Complete immutable-by-hash dry-run plan for one bounded submission.",
  "properties": {
    "backend_name": {
      "minLength": 1,
      "title": "Backend Name",
      "type": "string"
    },
    "compiler_target_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Compiler Target Hash",
      "type": "string"
    },
    "estimated_qpu_seconds": {
      "minimum": 0,
      "title": "Estimated Qpu Seconds",
      "type": "number"
    },
    "estimation_method": {
      "minLength": 1,
      "title": "Estimation Method",
      "type": "string"
    },
    "estimation_software_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Estimation Software Versions",
      "type": "object"
    },
    "estimation_version": {
      "minLength": 1,
      "title": "Estimation Version",
      "type": "string"
    },
    "instance_id": {
      "minLength": 1,
      "title": "Instance Id",
      "type": "string"
    },
    "instance_plan_type": {
      "enum": [
        "open",
        "paid"
      ],
      "title": "Instance Plan Type",
      "type": "string"
    },
    "maximum_execution_seconds": {
      "exclusiveMinimum": 0,
      "title": "Maximum Execution Seconds",
      "type": "number"
    },
    "partitions": {
      "items": {
        "$ref": "#/$defs/SubmissionPartition"
      },
      "minItems": 1,
      "title": "Partitions",
      "type": "array"
    },
    "plan_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Plan Hash",
      "type": "string"
    },
    "plan_id": {
      "minLength": 1,
      "title": "Plan Id",
      "type": "string"
    },
    "policy_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Policy Hash",
      "type": "string"
    },
    "primitive": {
      "enum": [
        "sampler",
        "estimator"
      ],
      "title": "Primitive",
      "type": "string"
    },
    "pub_shapes": {
      "items": {
        "$ref": "#/$defs/PubShape"
      },
      "minItems": 1,
      "title": "Pub Shapes",
      "type": "array"
    },
    "pubs": {
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/SamplerPubSpec"
          },
          {
            "$ref": "#/$defs/EstimatorPubSpec"
          }
        ]
      },
      "minItems": 1,
      "title": "Pubs",
      "type": "array"
    },
    "resolved_options": {
      "additionalProperties": true,
      "title": "Resolved Options",
      "type": "object"
    },
    "scheduled_estimates": {
      "items": {
        "$ref": "#/$defs/ScheduledPubEstimate"
      },
      "minItems": 1,
      "title": "Scheduled Estimates",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "submission_key": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Submission Key",
      "type": "string"
    },
    "target_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Target Hash",
      "type": "string"
    },
    "total_circuit_executions": {
      "exclusiveMinimum": 0,
      "title": "Total Circuit Executions",
      "type": "integer"
    },
    "treatments": {
      "items": {
        "type": "string"
      },
      "title": "Treatments",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "plan_id",
    "submission_key",
    "plan_hash",
    "policy_hash",
    "instance_id",
    "instance_plan_type",
    "backend_name",
    "target_hash",
    "compiler_target_hash",
    "primitive",
    "pubs",
    "pub_shapes",
    "resolved_options",
    "treatments",
    "partitions",
    "scheduled_estimates",
    "total_circuit_executions",
    "estimated_qpu_seconds",
    "maximum_execution_seconds",
    "estimation_method",
    "estimation_version",
    "estimation_software_versions"
  ],
  "title": "SubmissionPlan",
  "type": "object",
  "x-schema-version": "1.0"
}
